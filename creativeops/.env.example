# ── Required ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Real web search (Tavily) ─────────────────────────────────────────────────
# Sign up free at https://tavily.com — 1,000 free searches/month
TAVILY_API_KEY=tvly-...

# ── Email sending (SMTP) ─────────────────────────────────────────────────────
# Gmail: create an App Password at myaccount.google.com → Security → App passwords
# Then use:  SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com
#
# Other providers: Mailgun, SendGrid, Fastmail, Outlook — all use STARTTLS on 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=CreativeOps Studio <your@email.com>
SMTP_TLS=true
